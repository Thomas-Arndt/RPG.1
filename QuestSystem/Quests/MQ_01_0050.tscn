[node name="MQ_01_0050" instance=ExtResource( 1 )]
title = "Trapped Townspeople"
description = "Loni has informed us that a local named Dale might have useful information on what happened at the cave to the West. Speak with Dale and then return to Loni."
startText = [ "The letter says that the farm is overrun with monsters? That's really not good!", "I will go as soon as I am able, but first I am helping coordinate the rescue of most of the town.", "You heard me right. Most of the town is currently trapped in a cave to the west of here.", "I still don't have the whole story, but all that matters right now is that they need help.", "Perhaps you can find out more of what happened from Dale. He is the only person to have made it back.", "He lives in the Northwest-most house in town here. See if you can get any more info and then come back to me." ]
progressText = [ "Gladd to have you on the rescue effort!", "Remember, Dale lives in the Nowrthwest-most hou" ]
deliverText = [ "* * Knock knock * *", "..." ]

